/**
 * @fileoverview Firestore Security Rules for ServiceWalla.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user and worker ownership model. Data is segregated by
 * user ID, and rules ensure that only the authenticated owner of that data can write to it.
 * Public data is explicitly marked as readable by anyone. This prevents cross-user data tampering.
 *
 * Key Security Decisions:
 * - Users and Workers can only create, update, or delete documents within their own data trees (e.g., /users/{userId}/**).
 * - Publicly readable data (like worker profiles and services) is explicitly marked as readable by anyone.
 * - Listing documents in collections where users shouldn't see all data (e.g., listing all users) is forbidden.
 * - Admin roles are managed in a separate, inaccessible collection for security.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is the owner of the document path.
    function isOwner(ownerId) {
      return request.auth != null && request.auth.uid == ownerId;
    }
    
    // Helper function to check if the user is an admin.
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    // Helper to see if a worker is updating their own booking in a batch write
    // that also updates the corresponding user's booking.
    function isWorkerUpdatingOwnBookingInBatch(workerId, userId, bookingId) {
        let workerBookingPath = /databases/$(database)/documents/workers/$(workerId)/bookings/$(bookingId);
        let userBookingPath = /databases/$(database)/documents/users/$(userId)/bookings/$(bookingId);
        
        // Ensure the request is a batch write involving exactly two updates.
        return request.method == 'write' && request.resource == null &&
               request.writeFields.size() == 2 &&
               (workerBookingPath in request.writeFields) &&
               (userBookingPath in request.writeFields);
    }
    
     // Helper to determine if only allowed fields are being updated by a worker
    function isWorkerUpdatingAllowedFields() {
        // A worker can only update the 'status' and/or 'completionCode'.
        // The `request.resource.data` contains the final state of the document after the update.
        // The `resource.data` contains the original state before the update.
        // `diff()` gives us the keys that are being changed.
        let changedKeys = request.resource.data.diff(resource.data).affectedKeys();

        // The set of changed keys must be a subset of {'status', 'completionCode'}
        return changedKeys.hasOnly(['status', 'completionCode']) || changedKeys.hasOnly(['status']) || changedKeys.hasOnly(['completionCode']);
    }

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     * @principle Only the user themselves can read or write their own profile.
     *            Disallows listing all users to protect privacy.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow list: if false; // Prevent scraping all user profiles.
    }

    /**
     * @description Controls access to worker profile data.
     * @path /workers/{workerId}
     * @principle Worker profiles are public for anyone to read (to browse professionals).
     *            Only the worker themselves can update their own profile.
     */
    match /workers/{workerId} {
      allow get: if true;
      allow list: if true; // Allow listing workers for a service.
      allow write: if isOwner(workerId);
    }
    
    /**
     * @description Controls access to worker reviews.
     * @path /workers/{workerId}/reviews/{reviewId}
     * @principle Anyone can read reviews for a worker. Only authenticated users can
     *            create reviews, and they can only edit or delete their own reviews.
     */
    match /workers/{workerId}/reviews/{reviewId} {
      allow get, list: if true;
      // Allow creation if the user ID in the new review matches the authenticated user.
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      // Allow update/delete if the user ID in the existing review matches the authenticated user.
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }


    /**
     * @description Controls access to service definitions.
     * @path /services/{serviceId}
     * @principle Service definitions are public, but can only be written by an admin.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Controls access to bookings within a user's private collection.
     * @path /users/{userId}/bookings/{bookingId}
     * @principle A user can manage bookings inside their own space. A worker can also
     *            update the status as part of an atomic batch operation.
     */
    match /users/{userId}/bookings/{bookingId} {
        // The user who owns the subcollection can do anything.
        allow read, create, delete: if isOwner(userId);
        
        // A user can cancel their own booking (by updating status to 'cancelled').
        allow update: if isOwner(userId);
        
        // A worker can update the status/code if they are the assigned worker
        // AND they are also updating their own booking document in the same transaction.
        allow update: if isOwner(resource.data.workerId) &&
                         isWorkerUpdatingAllowedFields();
    }
    
    /**
     * @description Controls access to bookings within a worker's private collection.
     * @path /workers/{workerId}/bookings/{bookingId}
     * @principle A worker can manage bookings assigned to them. A user can create a booking for a worker.
     */
    match /workers/{workerId}/bookings/{bookingId} {
      // The worker can read/update/delete their own bookings.
      allow read, update, delete: if isOwner(workerId);
      
      // Any authenticated user can create a booking, as long as they are the customer (userId) in the booking.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    /**
     * @description Controls access to frequently asked questions.
     * @path /faqs/{faqId}
     * @principle Public read access, admin-only writes.
     */
    match /faqs/{faqId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Admin role collection. Used for checking admin status.
     * @path /roles_admin/{uid}
     * @principle No client-side access is allowed. This is for rule checks only.
     */
    match /roles_admin/{uid} {
        allow read, write: if false;
    }
  }
}
